# Cognis Studio — environment scaffold.
# Copy to .env.local and fill only the integrations you enable. All adapters
# degrade gracefully when their keys are absent; nothing here is required to build.

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_WAITLIST_URL=/waitlist

# --- Payments (Stripe + Link) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Scheduling ---
NEXT_PUBLIC_CALENDLY_URL=
CALENDLY_WEBHOOK_SIGNING_KEY=

# --- Email ---
RESEND_API_KEY=
EMAIL_FROM=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- AI ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Identity / KYC ---
PERSONA_API_KEY=
PERSONA_TEMPLATE_ID=

# --- CRM ---
HUBSPOT_ACCESS_TOKEN=

# --- Automation ---
ZAPIER_WEBHOOK_URL=
N8N_WEBHOOK_URL=
N8N_API_KEY=

# --- Messaging / analytics ---
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
SEGMENT_WRITE_KEY=

# --- Data linking ---
PLAID_CLIENT_ID=
PLAID_SECRET=

# --- Database ---
DATABASE_URL=file:./studio.sqlite
